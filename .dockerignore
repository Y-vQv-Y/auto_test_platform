# ============================================
# AI 自动测试平台 - Docker 构建忽略文件
# ============================================

# 版本控制
.git
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node
frontend/node_modules/
frontend/.npm/

# 运行时数据（由 Docker volume 挂载）
data/
logs/
test_reports/
generated_tests/

# 本地配置（生产环境通过环境变量传入）
.env
.env.local
*.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# 操作系统
.DS_Store
Thumbs.db

# 临时文件
*.log
*.tmp
